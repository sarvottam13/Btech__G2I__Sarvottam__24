#include<stdio.h>
int main()
{
int a[100],n,i,j,temp;
printf("enter the size of element of the array");
scanf("%d",&n);
printf("enter the element in an array");
for(i=0;i<n;i++)
{
scanf("%d",&a[i]);
}
printf("sort an array using selection sort=");
for(i=0;i<n-1;i++)
{
min=i;
for (j=i+1;j<n;j++)
{
if (a[min]>a[j])
{
min=j;
}
temp=a[i];
a[i]=a[min];
}
printf("sorted array=\n");
for (i=0;j<n;i++)
{
printf("a[%d]=%d\n",i,a[i]);
}
return 0;
}
